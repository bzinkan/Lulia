                  "max": 6,
                  "step": 1,
                  "value": 1
                }
              ]
            },
            "study_mode": {
              "prompt": "Change the rate and starting value. Watch how the graph and equation respond."
            },
            "practice_mode": {
              "prompt": "Predict the graph change before adjusting each slider."
            },
            "checks": [
              {
                "type": "multiple_choice",
                "question": "In d = 2t + 1, what does the 2 represent?",
                "choices": [
                  {
                    "id": "A",
                    "text": "The starting distance",
                    "correct": false
                  },
                  {
                    "id": "B",
                    "text": "The distance traveled each hour",
                    "correct": true
                  },
                  {
                    "id": "C",
                    "text": "The total distance after 1 hour only",
                    "correct": false
                  }
                ],
                "feedback": {
                  "correct": "Yes. The coefficient of t is the rate of change.",
