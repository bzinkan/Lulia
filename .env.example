# ============================================
# Lulia — Environment Configuration
# Copy to .env.development for local dev
# ============================================

# --- Environment ---
ENVIRONMENT=development

# --- Database ---
DB_HOST=db
DB_PORT=5432
DB_NAME=lulia
DB_USER=lulia
DB_PASSWORD=devpassword

# --- Object Storage (MinIO in dev, S3 in prod) ---
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_UPLOADS=lulia-uploads
S3_BUCKET_GENERATED=lulia-generated
S3_BUCKET_SCANS=lulia-scans
S3_BUCKET_TEMPLATES=lulia-templates
S3_BUCKET_ACTIVITIES=lulia-activities

# --- LLM: Claude API (Anthropic) ---
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- LLM: Gemini API (Google) ---
GOOGLE_GEMINI_API_KEY=your-gemini-api-key

# --- Embedding: AWS Bedrock ---
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0

# --- Google OAuth (Classroom, Drive, Calendar) ---
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_REDIRECT=http://localhost:8000/api/v1/classroom/auth/callback

# --- Token Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())") ---
TOKEN_ENCRYPTION_KEY=your-fernet-key

# --- Common Standards Project API ---
COMMON_STANDARDS_API_KEY=your-csp-api-key

# --- TTS / Video Pipeline ---
TTS_ENGINE=elevenlabs
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_DEFAULT_VOICE=21m00Tcm4TlvDq8ikWAM

# --- Email (console in dev, SES in prod) ---
EMAIL_BACKEND=console
# SES_REGION=us-east-1  # Uncomment for production

# --- Event Bus (postgres in dev, sqs in prod) ---
EVENT_BUS=postgres
# SQS_QUEUE_PREFIX=lulia-  # Uncomment for production

# --- Replicate (Lulings image generation) ---
REPLICATE_API_TOKEN=your-replicate-api-token

# --- Super Admin ---
SUPER_ADMIN_EMAILS=admin@lulia.com
ADMIN_PASSWORD=change-me-in-production

# --- Dashboard ---
DASHBOARD_URL=http://localhost:3001
API_URL=http://localhost:8000

# --- Auto-Planning ---
AUTO_PLAN_TIME=17:00
AUTO_PLAN_DAY=sunday
