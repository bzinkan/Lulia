# ============================================
# Lulia — Environment Configuration
# Copy to .env.development for local dev
# ============================================

# --- Environment ---
ENVIRONMENT=development

# --- Database ---
DB_HOST=db
DB_PORT=5432
DB_NAME=lulia
DB_USER=lulia
DB_PASSWORD=devpassword

# Pool bounds per API task. In prod, keep tasks × DB_POOL_MAX well under
# RDS `max_connections`. Default RDS small = 100 — 4 tasks × 20 = 80 works.
DB_POOL_MIN=2
DB_POOL_MAX=20
# Per-connection statement_timeout guard (milliseconds). Callers can still
# raise this via `SET LOCAL statement_timeout = ...` when they know a job is
# slow (backfills, alignment runs).
DB_STATEMENT_TIMEOUT_MS=30000

# --- API runtime ---
# Comma-separated allowlist for CORS. One per environment (local/staging/prod).
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# JSON logs in prod; "text" in dev for readable `docker compose logs`.
LOG_FORMAT=text
LOG_LEVEL=INFO

# Rate limiter (slowapi). Set RATE_LIMIT_STORAGE_URI=redis://redis:6379/1 in
# prod so counters are shared across Fargate tasks; otherwise each task
# enforces its own budget and the effective cap is tasks × per-route cap.
RATE_LIMIT_ENABLED=true
# RATE_LIMIT_STORAGE_URI=memory://

# Prod-only: hide stack traces from unhandled-exception JSON body. When ENV
# is one of {dev,local,test} the handler includes a `detail` field to help
# triage; in staging/prod it's suppressed to avoid leaking internals.
ENV=development

# --- Auth (Phase 28) ---
# 32+ char random string. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# REQUIRED in production; falls back to a derived dev secret only when unset.
JWT_SECRET=change-me-to-a-random-48+-char-string-in-prod
JWT_EXP_HOURS=168
# DEV_AUTH_BYPASS=1 lets routes accept the legacy `?teacher_id=<uuid>` query
# param when no Authorization header is present. KEEP THIS 1 in dev so the
# dashboard + scripts keep working during the auth rollout. Set to 0 in
# staging/prod — the dashboard MUST send Authorization: Bearer <jwt>.
DEV_AUTH_BYPASS=1

# --- Object Storage (MinIO in dev, S3 in prod) ---
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_UPLOADS=lulia-uploads
S3_BUCKET_GENERATED=lulia-generated
S3_BUCKET_SCANS=lulia-scans
S3_BUCKET_TEMPLATES=lulia-templates
S3_BUCKET_ACTIVITIES=lulia-activities

# --- LLM: Claude API (Anthropic) ---
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- LLM: Gemini API (Google) ---
GOOGLE_GEMINI_API_KEY=your-gemini-api-key

# --- Embedding: AWS Bedrock ---
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0

# --- Google OAuth (Classroom, Drive, Calendar) ---
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_REDIRECT=http://localhost:8000/api/v1/classroom/auth/callback

# --- Token Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())") ---
TOKEN_ENCRYPTION_KEY=your-fernet-key

# --- Common Standards Project API ---
COMMON_STANDARDS_API_KEY=your-csp-api-key

# --- TTS / Video Pipeline ---
TTS_ENGINE=elevenlabs
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_DEFAULT_VOICE=21m00Tcm4TlvDq8ikWAM

# --- Email (console in dev, SES in prod) ---
EMAIL_BACKEND=console
# SES_REGION=us-east-1  # Uncomment for production

# --- Event Bus (postgres in dev, sqs in prod) ---
EVENT_BUS=postgres
# SQS_QUEUE_PREFIX=lulia-  # Uncomment for production

# --- Replicate (Lulings image generation) ---
REPLICATE_API_TOKEN=your-replicate-api-token

# --- Super Admin ---
SUPER_ADMIN_EMAILS=admin@lulia.com
ADMIN_PASSWORD=change-me-in-production

# --- Dashboard ---
DASHBOARD_URL=http://localhost:3001
API_URL=http://localhost:8000

# --- Stripe ---
STRIPE_API_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_BASIC=price_xxx
STRIPE_PRICE_PLUS=price_xxx
STRIPE_PRICE_PREMIUM=price_xxx
STRIPE_PRICE_MAX=price_xxx
STRIPE_PRICE_CREDITS_50=price_xxx
STRIPE_PRICE_CREDITS_150=price_xxx
STRIPE_PRICE_CREDITS_500=price_xxx
STRIPE_PRICE_CREDITS_1500=price_xxx

# --- Auto-Planning ---
AUTO_PLAN_TIME=17:00
AUTO_PLAN_DAY=sunday
